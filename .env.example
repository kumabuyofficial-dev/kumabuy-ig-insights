# Required for public Instagram authorization and real report data.
PHYLLO_CLIENT_ID=
PHYLLO_CLIENT_SECRET=

# Use sandbox while testing. Switch to production only after Phyllo approves live access.
PHYLLO_ENVIRONMENT=sandbox
PHYLLO_BASE_URL=https://api.sandbox.getphyllo.com

# Optional. If set, Phyllo Connect opens Instagram directly instead of showing all platforms.
PHYLLO_INSTAGRAM_WORK_PLATFORM_ID=
PHYLLO_CLIENT_DISPLAY_NAME=熊熊跨麥
